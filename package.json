{
	"name": "blog",
	"private": true,
	"version": "0.0.1",
	"packageManager": "bun@1.2.13",
	"type": "module",
	"scripts": {
		"build:wasm": "bun scripts/build-wasm.mjs",
		"generate:post-components": "bun scripts/generate-post-components.mjs",
		"test:prebuild": "bun tests/prebuild-smoke.mjs",
		"test:tools-integrity": "bun tests/tool-integrity.mjs",
		"test:build-output": "bun tests/build-output-check.mjs",
		"test:perf-budgets": "bun tests/perf-budgets.mjs",
		"test:ci": "bun run check && bun run build && bun run test:build-output && bun run test:perf-budgets",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"predev": "POST_COMPONENT_MAP_MODE=dev bun run generate:post-components && bun run build:wasm",
		"prebuild": "POST_COMPONENT_MAP_MODE=prod bun run generate:post-components && bun run test:prebuild && bun run test:tools-integrity && bun run build:wasm",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@internationalized/date": "^3.11.0",
		"@lucide/svelte": "^0.575.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"bits-ui": "^2.16.2",
		"clsx": "^2.1.1",
		"github-slugger": "^2.0.0",
		"mdsvex": "^0.12.6",
		"rehype-katex": "^5.0.0",
		"rehype-slug": "^6.0.0",
		"remark-math": "^3.0.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"wabt": "^1.0.39"
	},
	"dependencies": {
		"mathjs": "^15.1.1"
	}
}
